{
  "name": "emoji-log-assistant",
  "displayName": "Emoji Log Assistant - Smart Emoji Logs",
  "description": "Automatically adds meaningful emojis to your logs, console.log, print, and debug statements. The most advanced emoji log assistant for all programming languages.",
  "version": "1.0.9",
  "publisher": "abhijeettiwari",
  "author": {
    "name": "Abhijeet Tiwari"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/abhijeettiwariplazza/emoji-logs-assistant"
  },
  "bugs": {
    "url": "https://github.com/abhijeettiwariplazza/emoji-logs-assistant/issues"
  },
  "homepage": "https://github.com/abhijeettiwariplazza/emoji-logs-assistant#readme",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Formatters",
    "Other"
  ],
  "keywords": [
    "emoji",
    "log",
    "logs",
    "emoji-log",
    "console.log",
    "debug",
    "logging",
    "formatter",
    "assistant",
    "smart-logs",
    "auto-emoji"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "emoji-log.addEmojis",
        "title": "Add Emojis to Console Logs"
      },
      {
        "command": "emoji-log.insertLog",
        "title": "Emoji Log: Insert suggested log statement"
      }
    ]
  },
  "dependencies": {
    "emojilib": "^4.0.2",
    "node-emoji": "^2.2.0"
  }
}
