{
  "Emoji Console Log": {
    "prefix": "clog",
    "body": ["console.log(\"👉 $1\");"],
    "description": "Emoji console.log statement"
  },
  "Emoji Console Error": {
    "prefix": "cerr",
    "body": ["console.error(\"🚨 $1\");"],
    "description": "Emoji console.error statement"
  },
  "Emoji Console Warn": {
    "prefix": "cwarn",
    "body": ["console.warn(\"⚠️ $1\");"],
    "description": "Emoji console.warn statement"
  },
  "Emoji Console Info": {
    "prefix": "cinfo",
    "body": ["console.info(\"ℹ️ $1\");"],
    "description": "Emoji console.info statement"
  },
  "Emoji Try-Catch Block": {
    "prefix": "etry",
    "body": [
      "try {",
      "  console.log(\"🔧 Trying: $1\");",
      "  $2",
      "} catch (${3:error}) {",
      "  console.error(\"🚨 Error in $1:\", ${3:error});",
      "}"
    ],
    "description": "Try-catch block with emoji logs"
  },
  "Emoji API Call Log": {
    "prefix": "apilog",
    "body": [
      "console.log(\"📡 Calling API: $1\");",
      "const ${2:response} = await $1;",
      "console.log(\"📥 Response:\", ${2:response});"
    ],
    "description": "API call with emoji logs"
  },
  "Emoji Function Log": {
    "prefix": "fnlog",
    "body": [
      "async function ${1:functionName}(${2:params}) {",
      "  console.log(\"🚀 ${1:functionName} called\", ${2:params});",
      "  try {",
      "    $3",
      "  } catch (error) {",
      "    console.error(\"🚨 ${1:functionName} failed:\", error);",
      "  }",
      "}"
    ],
    "description": "Async function with emoji logs"
  }
}
